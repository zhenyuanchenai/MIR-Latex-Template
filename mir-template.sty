  \renewcommand{\headrulewidth}{0pt}
  \renewcommand{\headrule}{\ifodd\value{page}\relax\else\hrule width\headwidth height0.4pt \vskip-\headrulewidth\fi}
  \renewcommand{\footrulewidth}{0pt}
}
