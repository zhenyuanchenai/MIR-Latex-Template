\makeatletter
\newcommand{\mir@abstract}{}
\newcommand{\mir@keywords}{}
\newcommand{\mir@affiliations}{}
\long\def\mir@splitbiography#1\par#2\mir@biographystop{%
  \long\def\mir@biographyfirst{#1}%
  \long\def\mir@biographyrest{#2}%
}
\newcommand{\mir@wrapbiographycontent}[4]{%
  \sbox{\mirbiophotobox}{#1}%
  \setbox\mirwrapbiobox=\vbox{%
    \hsize=\linewidth
    \justifying
    \setlength{\parindent}{0pt}%
    \setlength{\parskip}{1pt}%
    \hangindent=\dimexpr\wd\mirbiophotobox+\mirauthorphotogap\relax
    \hangafter=\numexpr-#4\relax
    \noindent\makebox[0pt][r]{%
      \raisebox{\dimexpr-\height+\ht\strutbox\relax}[0pt][0pt]{\usebox{\mirbiophotobox}}%
      \hspace{\mirauthorphotogap}}%
    \textbf{#2} #3\par
  }%
  \ifdim\ht\mirwrapbiobox<\dimexpr\ht\mirbiophotobox+\dp\mirbiophotobox\relax
    \vbox to \dimexpr\ht\mirbiophotobox+\dp\mirbiophotobox\relax{\unvbox\mirwrapbiobox\vfil}%
  \else
    \box\mirwrapbiobox
  \fi
}
\newcommand{\mirwrapbiography}[4][]{%
  \par\noindent
  \begingroup
  \mirwrapbiofont\justifying
  \mir@wrapbiographycontent{\mirbioincludegraphics[#1]{#2}}{#3}{#4}{\mirwrapbiolines}%
  \endgroup
  \par\vspace{\mirwrapbiosep}%
}
\NewEnviron{mirbiography}[3][]{%
  \mirwrapbiography[#1]{#2}{#3}{\BODY}%
}
\newenvironment{mirbiographies}[1][2]{%
  \par\vspace{\baselineskip}%
  \noindent
}{%
  \par
}
\newcommand{\miraffiliation}[1]{\gdef\mir@affiliations{#1}}
\RenewEnviron{abstract}{\global\let\mir@abstract\BODY}
\RenewEnviron{IEEEkeywords}{\global\let\mir@keywords\BODY}

\renewcommand{\maketitle}{%
  \thispagestyle{mirfirst}%
  \flushbottom
  \twocolumn[
  \begin{center}
    {\bfseries\fontsize{16pt}{18pt}\selectfont \@title\par}
    \vspace{25pt}
    {\fontsize{12pt}{14pt}\selectfont \@author\par}
    \ifstrempty{\mir@affiliations}{}{%
      \vspace{6pt}
      {\fontsize{8.5pt}{10.5pt}\selectfont \mir@affiliations\par}%
    }%
  \end{center}
  \vspace{13pt}
  \noindent{\bodyfont\textbf{Abstract:}\quad \mir@abstract\par}
  \vspace{10pt}
  \noindent{\bodyfont\textbf{Keywords:}\quad \mir@keywords\par}
  \vspace{30pt}
  ]%
  \bodyfont\justifying
}

\renewenvironment{thebibliography}[1]{%
  \section*{\fontsize{12pt}{12pt}\selectfont References}%
  \referencefont\justifying
  \list{\@biblabel{\@arabic\c@enumiv}}{%
    \settowidth\labelwidth{\@biblabel{#1}}%
    \leftmargin=0pt
    \labelwidth=0pt
    \labelsep=0.35em
    \itemindent=0pt
    \itemsep=0pt
    \parsep=0pt
    \usecounter{enumiv}%
    \let\p@enumiv\@empty
    \renewcommand\theenumiv{\@arabic\c@enumiv}}%
  \sloppy\clubpenalty4000\widowpenalty4000%
}{%
  \def\@noitemerr{\@latex@warning{Empty `thebibliography' environment}}%
  \endlist
}

\RenewEnviron{IEEEbiography}[2][]{%
  \par
  \ifcsdef{mir@seenbiography}{%
    \vspace{\baselineskip}%
    \def\mir@biographyneedspace{\mirnextbiographyneedspace}%
  }{%
    \vspace{\baselineskip}%
    \global\cslet{mir@seenbiography}\@empty
    \def\mir@biographyneedspace{\mirfirstbiographyneedspace}%
  }%
  \begingroup
  \biofont\justifying
  \noindent
  \ifstrempty{#1}{%
    \textbf{#2}\ \BODY\par
  }{%
    \Needspace{\mir@biographyneedspace}%
    \expandafter\mir@splitbiography\BODY\par\mir@biographystop
    \mir@wrapbiographycontent{#1}{#2}{\mir@biographyfirst}{\mirauthorphotolines}\par
    \mir@biographyrest\par
  }%
  \endgroup
}
